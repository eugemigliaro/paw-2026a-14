<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<property name="defaultPattern" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} [%thread] %-5level %logger{36} - %msg%n"/>

	<appender name="root-appender" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>logs/paw-2026a-14.warnings.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>logs/paw-2026a-14.warnings.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>5</maxHistory>
			<totalSizeCap>50MB</totalSizeCap>
			<cleanHistoryOnStart>true</cleanHistoryOnStart>
		</rollingPolicy>
		<encoder>
			<pattern>${defaultPattern:-}</pattern>
		</encoder>
	</appender>

	<appender name="paw-appender" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>logs/paw-2026a-14.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>logs/paw-2026a-14.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>5</maxHistory>
			<totalSizeCap>50MB</totalSizeCap>
			<cleanHistoryOnStart>true</cleanHistoryOnStart>
		</rollingPolicy>
		<encoder>
			<pattern>${defaultPattern:-}</pattern>
		</encoder>
	</appender>

	<root level="WARN">
		<appender-ref ref="root-appender"/>
	</root>

	<logger name="ar.edu.itba.paw" level="INFO" additivity="false">
		<appender-ref ref="paw-appender"/>
	</logger>

	<!-- Hibernate SQL logging (development only) -->
	<logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
		<appender-ref ref="paw-appender"/>
	</logger>
	<logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE" additivity="false">
		<appender-ref ref="paw-appender"/>
	</logger>
</configuration>
