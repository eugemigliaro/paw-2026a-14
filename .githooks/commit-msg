#!/bin/sh
set -eu

COMMIT_MSG_FILE="$1"

# Conventional Commits: type(scope?): subject
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .{1,}$'
MERGE_PATTERN='^Merge .+$'

if ! grep -Eq "$PATTERN|$MERGE_PATTERN" "$COMMIT_MSG_FILE"; then
	echo "Invalid commit message format."
	echo "Use Conventional Commits or merge commits, for example:"
	echo "  feat(webapp): add demo card component"
	echo "  fix(services): validate null user id"
	echo "  chore: update dependencies"
	echo "  Merge branch 'feature/login' into 'main'"
	exit 1
fi
